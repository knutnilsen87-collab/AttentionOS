{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "project_name",
    "project_root",
    "project_type",
    "project_state_confidence",
    "current_phase",
    "last_action",
    "last_result",
    "next_action",
    "verification_level",
    "top_blocker",
    "risks"
  ],
  "properties": {
    "project_name": {
      "type": "string"
    },
    "project_root": {
      "type": "string"
    },
    "project_type": {
      "type": "string"
    },
    "project_state_confidence": {
      "type": "string"
    },
    "current_phase": {
      "type": "string"
    },
    "last_action": {
      "type": "string"
    },
    "last_result": {
      "type": "string"
    },
    "next_action": {
      "type": "string"
    },
    "verification_level": {
      "type": "string"
    },
    "top_blocker": {
      "type": "string"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "build_status": {
      "type": "string"
    },
    "runtime_status": {
      "type": "string"
    },
    "test_status": {
      "type": "string"
    }
  }
}
